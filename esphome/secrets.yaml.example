# secrets.yaml.example
# Copy this file to secrets.yaml and fill in your actual values.
# secrets.yaml is gitignored and never committed.

wifi_ssid: "Your WiFi Network Name"
wifi_password: "your_wifi_password"

# Generate a random 32-byte base64 key, e.g.:
#   python3 -c "import base64, os; print(base64.b64encode(os.urandom(32)).decode())"
smartdisplay_api_key: "your_32_byte_base64_api_key_here="

# Any string works as OTA password
ota_password: "your_ota_password"

# Password for the fallback hotspot (shown when WiFi is unavailable)
wifi_ap_password: "your_fallback_password"
